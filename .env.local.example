# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/codeui

# Authentication (NextAuth)
AUTH_SECRET=your-auth-secret-generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Google OAuth must allow these redirect URIs:
# http://localhost:3000/api/auth/callback/google
# https://your-production-domain/api/auth/callback/google

# SMTP mailer for password reset and email verification
# Required for production email delivery. If omitted locally, auth links are logged to the server console.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=CodeUI <no-reply@example.com>

# OpenRouter AI API
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional: Comma-separated list of enabled model IDs
# ENABLED_AI_MODELS=google/gemini-3-flash-preview,deepseek/deepseek-chat

# Optional: Admin emails with unlimited access (comma-separated)
# ADMIN_EMAILS=admin@example.com,owner@example.com

# Stripe Payments
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Stripe Price IDs (for subscription tier mapping)
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxx
STRIPE_PROPLUS_MONTHLY_PRICE_ID=price_xxx
STRIPE_PROPLUS_YEARLY_PRICE_ID=price_xxx
STRIPE_TOPUP_25_PRICE_ID=price_xxx
STRIPE_TOPUP_50_PRICE_ID=price_xxx
STRIPE_TOPUP_100_PRICE_ID=price_xxx

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
