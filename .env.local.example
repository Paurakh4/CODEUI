# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/codeui

# Authentication (NextAuth)
AUTH_SECRET=your-auth-secret-generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Google OAuth must allow these redirect URIs:
# http://localhost:3000/api/auth/callback/google
# https://your-production-domain/api/auth/callback/google

# Email delivery for password reset and email verification.
# Choose ONE of the following providers. If neither is set, auth links are
# logged to the server console (development only).
#
# Option 1 (recommended): Gmail with an App Password
#   1. Enable 2-Step Verification on the Google account
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Paste the 16-character value into GMAIL_APP_PASSWORD (spaces are ok)
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# GMAIL_FROM=CodeUI <you@gmail.com>   # optional; defaults to GMAIL_USER
#
# Option 2: Generic SMTP server
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=CodeUI <no-reply@example.com>

# OpenRouter AI API
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional: Comma-separated list of enabled model IDs
# ENABLED_AI_MODELS=google/gemini-3-flash-preview,deepseek/deepseek-chat
# Optional: Baseline default model ID. Must also be enabled.
# DEFAULT_AI_MODEL=deepseek/deepseek-chat
# Optional: Ordered generation fallback model IDs. Must also be enabled.
# FALLBACK_AI_MODELS=deepseek/deepseek-r1,google/gemini-3-flash-preview
# Optional: Model id used for Prompt Enhance. Defaults to x-ai/grok-build-0.1
# PROMPT_ENHANCE_MODEL=x-ai/grok-build-0.1

# Optional: Admin emails with unlimited access (comma-separated)
# ADMIN_EMAILS=admin@example.com,owner@example.com

# Stripe Payments
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Stripe Price IDs (for subscription tier mapping)
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxx
STRIPE_PROPLUS_MONTHLY_PRICE_ID=price_xxx
STRIPE_PROPLUS_YEARLY_PRICE_ID=price_xxx
STRIPE_TOPUP_25_PRICE_ID=price_xxx
STRIPE_TOPUP_50_PRICE_ID=price_xxx
STRIPE_TOPUP_100_PRICE_ID=price_xxx

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
